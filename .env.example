# BambuDash Environment Variables
# Copy this file to .env and adjust the values for your environment.

# ==============================================================================
# Database Configuration
# ==============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bambudash

# DATABASE_URL is constructed automatically in docker-compose, but you can override it here
# DATABASE_URL=postgresql://postgres:changeme@db:5432/bambudash

# ==============================================================================
# Backend Configuration
# ==============================================================================
SECRET_KEY=change-me-in-production-with-a-secure-random-key

# Local MQTT Broker Settings (e.g. for P2S direct connection)
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Bambu Cloud Settings (e.g. for X2D printer connection via cloud)
BAMBU_CLOUD_HOST=us.mqtt.bambulab.com
BAMBU_CLOUD_PORT=8883
BAMBU_CLOUD_USERNAME=
BAMBU_CLOUD_PASSWORD=

# ==============================================================================
# Frontend Configuration
# ==============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
