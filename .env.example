# BambuDash Environment Variables
# Copy this file to .env and adjust the values for your environment.

# ==============================================================================
# Database Configuration
# ==============================================================================
POSTGRES_USER=your_postgres_user_here
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=bambudash

# DATABASE_URL is required by the backend.
# For Docker Compose deployment:
DATABASE_URL=postgresql://your_postgres_user_here:your_secure_password_here@db:5432/bambudash
# For local dev running outside Docker:
# DATABASE_URL=postgresql://your_postgres_user_here:your_secure_password_here@localhost:5432/bambudash

# ==============================================================================
# Backend Configuration
# ==============================================================================
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=your_secure_jwt_secret_key_here

# Local MQTT Broker Settings (e.g. for P2S direct connection)
MQTT_BROKER_HOST=your_mqtt_broker_host_here
MQTT_BROKER_PORT=1883
MQTT_USERNAME=your_mqtt_username_here
MQTT_PASSWORD=your_mqtt_password_here

# Bambu Cloud Settings (e.g. for X2D printer connection via cloud)
BAMBU_CLOUD_HOST=us.mqtt.bambulab.com
BAMBU_CLOUD_PORT=8883
BAMBU_CLOUD_USERNAME=your_bambu_cloud_username_here
BAMBU_CLOUD_PASSWORD=your_bambu_cloud_password_here

# ==============================================================================
# Frontend Configuration
# ==============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
